# Canonical site URL for sitemap, Open Graph, and JSON-LD (no trailing slash)
SITE_URL=https://localhost:3000

# Neon / Postgres
DATABASE_URL=

# Admin auth
ADMIN_PASSWORD=
# Generate with: openssl rand -hex 32
ADMIN_SESSION_SECRET=

# GitHub Actions dispatch
# Repo is "owner/name". Token is a fine-grained PAT with Actions: read/write.
GITHUB_REPO=
GITHUB_REF=main
GITHUB_DISPATCH_TOKEN=
